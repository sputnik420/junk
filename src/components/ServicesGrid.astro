---
import { business } from '../data/business';

interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;

const dict = {
  en: {
    title: "Junk Removal Services",
    subtitle: "From single-item pickups to full cleanouts, we help clear the clutter quickly and safely.",
    services: [
      { title: "Furniture Removal", desc: "Couches, mattresses, dressers, tables, chairs, office furniture, and more." },
      { title: "Appliance Removal", desc: "Refrigerators, washers, dryers, stoves, freezers, and other bulky appliances." },
      { title: "Garage Cleanouts", desc: "Boxes, clutter, old tools, storage items, trash, and unwanted household items." },
      { title: "House & Apartment Cleanouts", desc: "Move-outs, rental cleanups, estate cleanouts, and general junk removal." },
      { title: "Yard Waste Removal", desc: "Branches, leaves, outdoor junk, patio furniture, fencing debris, and more." },
      { title: "Construction Debris Removal", desc: "Light remodeling debris, wood, drywall, flooring, cabinets, and job-site cleanup." },
      { title: "Commercial Junk Removal", desc: "Office cleanouts, retail spaces, warehouses, property management, and business junk removal." }
    ],
    notSure: "Not sure if we take it?",
    textUs: "Text Us a Photo"
  },
  es: {
    title: "Servicios de Retiro de Basura",
    subtitle: "Desde un solo artículo hasta limpiezas completas, ayudamos a despejar su espacio de manera rápida y segura.",
    services: [
      { title: "Retiro de Muebles", desc: "Sofás, colchones, cómodas, mesas, sillas, muebles de oficina y más." },
      { title: "Retiro de Electrodomésticos", desc: "Refrigeradores, lavadoras, secadoras, estufas, congeladores y más." },
      { title: "Limpieza de Garajes", desc: "Cajas, desorden, herramientas viejas, artículos de almacenamiento, basura." },
      { title: "Limpieza de Casas y Apartamentos", desc: "Mudanzas, limpiezas de alquiler, limpiezas de bienes raíces y recolección general." },
      { title: "Retiro de Desechos de Jardín", desc: "Ramas, hojas, basura al aire libre, muebles de patio, escombros de cercas y más." },
      { title: "Escombros de Construcción", desc: "Escombros ligeros de remodelación, madera, paneles de yeso, pisos, gabinetes." },
      { title: "Retiro Comercial", desc: "Limpiezas de oficinas, espacios comerciales, almacenes, administración de propiedades." }
    ],
    notSure: "¿No está seguro si lo llevamos?",
    textUs: "Envíenos una Foto"
  }
};

const t = dict[lang];
---

<section id="services" class="section services-section">
  <div class="container">
    <div class="text-center mb-5">
      <h2>{t.title}</h2>
      <p class="subtitle">{t.subtitle}</p>
    </div>
    
    <div class="services-grid">
      {t.services.map(service => (
        <div class="card service-card">
          <h3 class="service-title">{service.title}</h3>
          <p class="service-desc">{service.desc}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-5">
      <p class="services-cta-text">{t.notSure}</p>
      <a href={`sms:${business.phoneTel}`} class="btn btn-primary mt-2" data-cta="text" data-location="services">
        {t.textUs}
      </a>
    </div>
  </div>
</section>

<style>
  .subtitle {
    font-size: 1.1rem;
    color: var(--color-soft-black);
    max-width: 600px;
    margin: 0 auto;
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  
  .service-card {
    border-top: 4px solid var(--color-primary-green);
  }
  
  .service-title {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--color-deep-black);
  }
  
  .service-desc {
    color: var(--color-soft-black);
    font-size: 0.95rem;
  }
  
  .services-cta-text {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-deep-black);
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
