---
import { business } from '../data/business';

interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;

const dict = {
  en: {
    title: "Trusted by Local Customers",
    findUs: "Find us on Google",
    leaveReview: "Leave a Review",
    readReviews: "Read Our Google Reviews",
    neutralTitle: "Find ANSEB Junk Removal on Google",
    neutralText: "Visit our Google Business Profile for the latest business information and customer feedback."
  },
  es: {
    title: "Recomendado por Clientes Locales",
    findUs: "Encuéntranos en Google",
    leaveReview: "Déjanos una Reseña",
    readReviews: "Leer Reseñas en Google",
    neutralTitle: "Encuentre ANSEB Junk Removal en Google",
    neutralText: "Visite nuestro perfil de Google para consultar la información más reciente del negocio y las opiniones disponibles."
  }
};
const t = dict[lang];

let { showGoogleReviews, googleBusinessProfileUrl, googleReviewUrl, googlePlaceId } = business;

let reviewsData: any[] = [];
let googleRating = 0;
let googleReviewCount = 0;
let hasRealReviews = false;

if (showGoogleReviews && googlePlaceId) {
  try {
    const apiKey = import.meta.env.GMAPAPI || process.env.GMAPAPI;
    
    if (apiKey) {
      // New Google Places API v1
      const languageCode = lang === 'es' ? 'es' : 'en';
      const response = await fetch(`https://places.googleapis.com/v1/places/${googlePlaceId}?languageCode=${languageCode}`, {
        headers: {
          'X-Goog-Api-Key': apiKey,
          'X-Goog-FieldMask': 'rating,userRatingCount,reviews,googleMapsUri'
        }
      });
      
      const data = await response.json();
      
      if (response.ok && data) {
        googleRating = data.rating || 0;
        googleReviewCount = data.userRatingCount || 0;
        
        if (googleReviewCount > 0) {
          hasRealReviews = true;
        }

        if (data.reviews && data.reviews.length > 0) {
          // Get top 3 positive reviews
          reviewsData = data.reviews
            .filter((r: any) => r.rating >= 4)
            .slice(0, 3);
        }
      } else {
        console.warn("Google Maps API Error:", data.error?.message || response.statusText);
      }
    } else {
      console.warn("GMAPAPI secret is not set. Showing neutral fallback.");
    }
  } catch (e) {
    console.error("Error fetching Google Reviews", e);
  }
}
---

<section class="section section-gray google-reviews-section">
  <div class="container text-center">
    
    {!hasRealReviews && (
      <div class="basic-reputation">
        <h2 class="mb-4">{t.neutralTitle}</h2>
        <p style="max-width: 600px; margin: 0 auto; color: var(--color-soft-black);">{t.neutralText}</p>
        <div class="ctas mt-4">
          <a href={googleBusinessProfileUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-cta="google-profile" data-location="reviews-section">
            {t.findUs}
          </a>
        </div>
      </div>
    )}

    {hasRealReviews && (
      <div class="real-reviews">
        <h2 class="mb-4">{t.title}</h2>
        <div class="rating-summary mb-4">
          <div class="stars">
            <span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span>
          </div>
          <p class="rating-text">
            <strong>{googleRating}</strong> / 5.0 based on <strong>{googleReviewCount}</strong> reviews
          </p>
        </div>

        <div class="reviews-grid mb-4">
          {reviewsData.map((review) => (
            <div class="card review-card text-left">
              <div class="review-header">
                {review.authorAttribution?.photoUri ? (
                  <img src={review.authorAttribution.photoUri} alt={review.authorAttribution.displayName} class="reviewer-img" loading="lazy" decoding="async" width="40" height="40" />
                ) : (
                  <div class="reviewer-initial">
                    {review.authorAttribution?.displayName ? review.authorAttribution.displayName.charAt(0) : 'C'}
                  </div>
                )}
                
                <div class="reviewer-info">
                  <strong>
                    {review.authorAttribution?.uri ? (
                      <a href={review.authorAttribution.uri} target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: none;">
                        {review.authorAttribution.displayName || 'Customer'}
                      </a>
                    ) : (
                      review.authorAttribution?.displayName || 'Customer'
                    )}
                  </strong>
                  <span class="review-date">{review.relativePublishTimeDescription || 'Recently'}</span>
                </div>
              </div>
              <div class="review-stars">
                {Array.from({ length: review.rating || 5 }).map(() => (
                  <span>★</span>
                ))}
              </div>
              <p class="review-body">
                "{review.text?.text || review.text}"
              </p>
            </div>
          ))}
        </div>

        <div class="ctas">
          <a href={googleBusinessProfileUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline" data-cta="read-reviews" data-location="reviews-section">
            {t.readReviews}
          </a>
          <a href={googleReviewUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-cta="leave-review" data-location="reviews-section">
            {t.leaveReview}
          </a>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .google-reviews-section h2 {
    color: var(--color-deep-black);
  }
  .ctas {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .stars {
    font-size: 2rem;
    color: #FABB05;
  }
  .rating-text {
    font-size: 1.1rem;
    color: var(--color-soft-black);
  }
  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .review-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .reviewer-initial {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--color-primary-green);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.2rem;
    text-transform: uppercase;
  }
  .reviewer-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
  }
  .reviewer-info {
    display: flex;
    flex-direction: column;
  }
  .review-date {
    font-size: 0.8rem;
    color: var(--color-medium-gray);
  }
  .review-stars {
    color: #FABB05;
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }
  .review-body {
    font-size: 0.95rem;
    color: var(--color-soft-black);
    line-height: 1.5;
  }
</style>
