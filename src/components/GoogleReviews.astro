---
import { business } from '../data/business';

interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;

const dict = {
  en: {
    title: "Trusted by Local Customers",
    findUs: "Find us on Google",
    leaveReview: "Leave a Review",
    readReviews: "Read Our Google Reviews",
    monthsAgo: "months ago",
    weeksAgo: "weeks ago",
    daysAgo: "days ago"
  },
  es: {
    title: "Recomendado por Clientes Locales",
    findUs: "Encuéntranos en Google",
    leaveReview: "Déjanos una Reseña",
    readReviews: "Leer Reseñas en Google",
    monthsAgo: "meses atrás",
    weeksAgo: "semanas atrás",
    daysAgo: "días atrás"
  }
};
const t = dict[lang];

let { showGoogleReviews, googleRating, googleReviewCount, googleBusinessProfileUrl, googleReviewUrl, googlePlaceId } = business;

let reviewsData = [];

if (showGoogleReviews && googlePlaceId) {
  try {
    // Attempt to get the API key from environment variables (build time)
    const apiKey = import.meta.env.GMAPAPI || process.env.GMAPAPI;
    
    if (apiKey) {
      const response = await fetch(`https://maps.googleapis.com/maps/api/place/details/json?place_id=${googlePlaceId}&fields=rating,user_ratings_total,reviews&key=${apiKey}&language=${lang}`);
      const data = await response.json();
      
      if (data.result) {
        googleRating = data.result.rating || googleRating;
        googleReviewCount = data.result.user_ratings_total || googleReviewCount;
        if (data.result.reviews) {
          // Get top 3 positive reviews (4 or 5 stars)
          reviewsData = data.result.reviews
            .filter((r: any) => r.rating >= 4)
            .slice(0, 3);
        }
      } else {
        console.warn("Google Maps API Error:", data.status, data.error_message);
      }
    } else {
      console.warn("GMAPAPI secret is not set. Using fallback reviews.");
    }
  } catch (e) {
    console.error("Error fetching Google Reviews", e);
  }
}

// Fallback hardcoded reviews if API fails, no key is provided, or no reviews exist yet
if (reviewsData.length === 0) {
  reviewsData = [
    {
      author_name: "Customer Name",
      rating: 5,
      relative_time_description: "1 month ago",
      text: "Great service! They arrived on time and cleared out our entire garage quickly. Highly recommended."
    },
    {
      author_name: "Customer Name",
      rating: 5,
      relative_time_description: "2 weeks ago",
      text: "Very professional and affordable. Removed my old couch and fridge without any issues."
    },
    {
      author_name: "Customer Name",
      rating: 5,
      relative_time_description: "3 months ago",
      text: "Fast communication and same-day pickup. Left the space completely clean."
    }
  ];
}
---

<section class="section section-gray google-reviews-section">
  <div class="container text-center">
    <h2 class="mb-4">{t.title}</h2>
    
    {!showGoogleReviews && (
      <div class="basic-reputation">
        <div class="ctas mt-3">
          <a href={googleBusinessProfileUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline" data-cta="google-profile" data-location="reviews-section">
            {t.findUs}
          </a>
          <a href={googleReviewUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-cta="leave-review" data-location="reviews-section">
            {t.leaveReview}
          </a>
        </div>
      </div>
    )}

    {showGoogleReviews && (
      <div class="real-reviews">
        <div class="rating-summary mb-4">
          <div class="stars">
            <span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span>
          </div>
          <p class="rating-text">
            <strong>{googleRating}</strong> / 5.0 based on <strong>{googleReviewCount}</strong> reviews
          </p>
        </div>

        <div class="reviews-grid mb-4">
          {reviewsData.map((review) => (
            <div class="card review-card text-left">
              <div class="review-header">
                <div class="reviewer-initial">{review.author_name.charAt(0)}</div>
                <div class="reviewer-info">
                  <strong>{review.author_name}</strong>
                  <span class="review-date">{review.relative_time_description}</span>
                </div>
              </div>
              <div class="review-stars">
                {Array.from({ length: review.rating }).map(() => (
                  <span>★</span>
                ))}
              </div>
              <p class="review-body">
                "{review.text}"
              </p>
            </div>
          ))}
        </div>

        <div class="ctas">
          <a href={googleBusinessProfileUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline" data-cta="read-reviews" data-location="reviews-section">
            {t.readReviews}
          </a>
          <a href={googleReviewUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-cta="leave-review" data-location="reviews-section">
            {t.leaveReview}
          </a>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .google-reviews-section h2 {
    color: var(--color-deep-black);
  }
  .ctas {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .stars {
    font-size: 2rem;
    color: #FABB05; /* Google Yellow */
    margin-bottom: 0.5rem;
  }
  .rating-text {
    font-size: 1.1rem;
    color: var(--color-soft-black);
  }
  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .review-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .reviewer-initial {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--color-primary-green);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.2rem;
    text-transform: uppercase;
  }
  .reviewer-info {
    display: flex;
    flex-direction: column;
  }
  .review-date {
    font-size: 0.8rem;
    color: var(--color-medium-gray);
  }
  .review-stars {
    color: #FABB05;
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }
  .review-body {
    font-size: 0.95rem;
    color: var(--color-soft-black);
    line-height: 1.5;
  }
</style>
