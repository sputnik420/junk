---
import { business } from '../data/business';

interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;

const dict = {
  en: {
    title: "Serving Houston & Surrounding Areas",
    text: `${business.name} serves customers throughout the Houston area.`,
    cta: "Don't see your area? Contact us and we'll let you know if we can help.",
    contact: "Contact Us"
  },
  es: {
    title: "Sirviendo a Houston y Áreas Circundantes",
    text: `${business.name} atiende a clientes en toda el área de Houston.`,
    cta: "¿No ve su área? Contáctenos y le diremos si podemos ayudarle.",
    contact: "Contáctenos"
  }
};
const t = dict[lang];
---

<section id="areas" class="section section-gray">
  <div class="container text-center">
    <h2 class="mb-3">{t.title}</h2>
    <p class="mb-4">{t.text}</p>
    
    <div class="areas-grid mb-4">
      {business.serviceArea.map(area => (
        <span class="area-badge">{area}</span>
      ))}
    </div>
    
    <p class="mb-3"><strong>{t.cta}</strong></p>
    <a href={lang === 'en' ? '/contact' : '/es/contact'} class="btn btn-secondary">
      {t.contact}
    </a>
  </div>
</section>

<style>
  .areas-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .area-badge {
    background-color: var(--color-white);
    color: var(--color-deep-black);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.95rem;
    font-weight: 600;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    border: 1px solid var(--color-soft-gray);
  }
</style>
