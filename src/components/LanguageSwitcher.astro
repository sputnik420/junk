---
import { business } from '../data/business';

interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;

const currentPath = Astro.url.pathname;
const isEs = lang === 'es';
const targetLang = isEs ? 'en' : 'es';

// Get base path mapping
const rawPath = currentPath.replace(import.meta.env.BASE_URL, '/').replace(/\/+/g, '/');

const pathMap: Record<string, string> = {
  '/': '/es/',
  '/services/': '/es/servicios/',
  '/contact/': '/es/contacto/',
  '/privacy/': '/es/privacidad/',
  '/terms/': '/es/terminos/',
  '/es/': '/',
  '/es/servicios/': '/services/',
  '/es/contacto/': '/contact/',
  '/es/privacidad/': '/privacy/',
  '/es/terminos/': '/terms/'
};

// Ensure trailing slash for mapping match
const normalizedPath = rawPath.endsWith('/') ? rawPath : rawPath + '/';
let mappedPath = pathMap[normalizedPath] || (isEs ? '/' : '/es/');

// Construct final target URL
const targetUrl = (import.meta.env.BASE_URL + mappedPath.substring(1)).replace(/\/+/g, '/');
---

<div class="language-switcher">
  <a 
    href={targetUrl} 
    class={`lang-toggle ${isEs ? 'active-es' : 'active-en'}`}
    data-cta="language-switch" 
    data-language={targetLang}
    aria-label={`Switch to ${targetLang === 'en' ? 'English' : 'Spanish'}`}
  >
    <span class={!isEs ? 'active' : ''}>EN</span>
    <span class="divider">|</span>
    <span class={isEs ? 'active' : ''}>ES</span>
  </a>
</div>

<style>
  .language-switcher {
    display: inline-flex;
    align-items: center;
  }
  .lang-toggle {
    display: flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-medium-gray);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    background: var(--color-light-bg);
    border: 1px solid var(--color-soft-gray);
    transition: all 0.2s ease;
  }
  .lang-toggle:hover {
    border-color: var(--color-primary-green);
  }
  .lang-toggle .divider {
    margin: 0 0.4rem;
    color: var(--color-soft-gray);
  }
  .lang-toggle span.active {
    color: var(--color-primary-green);
  }
</style>
