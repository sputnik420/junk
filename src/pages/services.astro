---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import CTASection from '../components/CTASection.astro';
const title = 'Junk Removal Services in Houston | ANSEB';
const description = 'Furniture removal, appliance removal, garage cleanouts, property cleanouts, yard waste and light construction debris removal in the Houston area.';
const lang = 'en';
---

<BaseLayout 
  lang={lang} 
  title={title}
  description={description}
  canonicalPath="/services/"
  alternatePath="/es/servicios/"
>
  <Header lang={lang} />
  
  <main>
    <section class="section section-gray">
      <div class="container text-center">
        <h1>Junk Removal Services in Houston, TX</h1>
        <p style="font-size: 1.1rem; max-width: 600px; margin: 0 auto; color: var(--color-soft-black);">
          We offer a full range of junk removal services for residential and commercial customers.
        </p>
      </div>
    </section>

    <ServicesGrid lang={lang} />
    
    <CTASection lang={lang} />
  </main>
  
  <Footer lang={lang} />
</BaseLayout>
