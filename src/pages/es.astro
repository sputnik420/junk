---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import { business } from '../data/business';

const lang = 'es';
const title = `Junk Removal en Houston, TX | ${business.name}`;
const description = `¿Necesita remover basura en Houston, TX? ${business.name} ofrece retiro de muebles, electrodomésticos, limpieza de garaje y más. Llame para un estimado gratis.`;
---

<BaseLayout lang={lang} title={title} description={description}>
  <Header lang={lang} />
  
  <main>
    <Hero lang={lang} />
    <ServicesGrid lang={lang} />
    <HowItWorks lang={lang} />
    <WhyChooseUs lang={lang} />

    <!-- Resultados reales -->
    <section class="section section-gray">
      <div class="container">
        <div class="text-center mb-4">
          <h2>Resultados Reales</h2>
          <p style="max-width: 520px; margin: 0 auto; color: var(--color-soft-black);">Antes y después de trabajos reales de retiro de basura en hogares y propiedades del área de Houston.</p>
        </div>
        <div style="max-width: 960px; margin: 0 auto; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
          <picture>
            <source 
              srcset={`${import.meta.env.BASE_URL}images/results-before-after.webp`} 
              type="image/webp" 
            />
            <img 
              src={`${import.meta.env.BASE_URL}images/results-before-after.jpg`} 
              alt="Antes y después: Espacio saturado de escombros convertido en un área limpia gracias a ANSEB Junk Removal" 
              style="width: 100%; display: block;"
              width="960"
              height="540"
            />
          </picture>
        </div>
      </div>
    </section>
    <GoogleReviews lang={lang} />
    <ServiceAreas lang={lang} />
    
    <section class="section">
      <div class="container" style="max-width: 800px; margin: 0 auto;">
        <div id="estimate-form-container-es"></div>
      </div>
    </section>
    
    <FAQ lang={lang} />
    <CTASection lang={lang} />
  </main>
  
  <Footer lang={lang} />
  <StickyMobileCTA lang={lang} />
</BaseLayout>

<script>
  import React from 'react';
  import { createRoot } from 'react-dom/client';
  import EstimateForm from '../components/EstimateForm';

  const container = document.getElementById('estimate-form-container-es');
  if (container) {
    const root = createRoot(container);
    root.render(React.createElement(EstimateForm, { lang: 'es' }));
  }
</script>
