---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
import EstimateForm from '../components/EstimateForm';

const lang = 'en';
const title = 'Junk Removal Houston, TX | ANSEB Junk Removal';
const description = 'Fast, reliable junk removal in Houston and nearby areas. Furniture, appliances, garage cleanouts, yard waste and light construction debris. Call or text photos for a free estimate.';
---

<BaseLayout 
  lang={lang} 
  title={title} 
  description={description}
  canonicalPath="/"
  alternatePath="/es/"
>
  <Header lang={lang} />
  
  <main>
    <Hero lang={lang} />
    <ServicesGrid lang={lang} />
    <HowItWorks lang={lang} />
    <WhyChooseUs lang={lang} />

    <!-- Real Results from actual jobs -->
    <section class="section section-gray">
      <div class="container">
        <div class="text-center mb-4">
          <h2>Real Results</h2>
          <p style="max-width: 520px; margin: 0 auto; color: var(--color-soft-black);">Before &amp; after from actual junk removal jobs in Houston area homes and properties.</p>
        </div>
        <div style="max-width: 960px; margin: 0 auto; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
          <picture>
            <source 
              srcset={`${import.meta.env.BASE_URL}images/results-before-after.webp`} 
              type="image/webp" 
            />
            <img 
              src={`${import.meta.env.BASE_URL}images/results-before-after.jpg`} 
              alt="Before and after: Cluttered space transformed into a clean, empty area by ANSEB Junk Removal" 
              style="width: 100%; display: block;"
              width="960"
              height="540"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </div>
      </div>
    </section>
    <GoogleReviews lang={lang} />
    <ServiceAreas lang={lang} />
    
    <section class="section">
      <div class="container" style="max-width: 800px; margin: 0 auto;">
        <EstimateForm client:load lang={lang} />
      </div>
    </section>
    
    <FAQ lang={lang} />
    <CTASection lang={lang} />
  </main>
  
  <Footer lang={lang} />
</BaseLayout>
