---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { business } from '../../data/business';

const title = "Estimado Gratis de Junk Removal en Houston | ANSEB";
const lang='es';
---

<BaseLayout lang={lang} title={title}>
  <Header lang={lang} />
  
  <main>
    <section class="section section-gray">
      <div class="container text-center">
        <h1>Contact Us</h1>
        <p style="font-size: 1.1rem; max-width: 600px; margin: 0 auto; color: var(--color-soft-black);">
          Ready to get started? Fill out the form below or contact us directly.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container" style="display: grid; grid-template-columns: 1fr; gap: 3rem;">
        
        <div class="contact-info" style="text-align: center;">
          <h2 class="mb-3">Get in Touch</h2>
          <p class="mb-2"><strong>Phone:</strong> <a href={`tel:${business.phoneTel}`}>{business.phoneDisplay}</a></p>
          <p class="mb-2"><strong>Email:</strong> <a href={`mailto:${business.email}`}>{business.email}</a></p>

          
          <div style="display: flex; justify-content: center; gap: 1rem;">
            <a href={`tel:${business.phoneTel}`} class="btn btn-primary" data-cta="call" data-location="contact">
              Call Now
            </a>
            <a href={`sms:${business.phoneTel}`} class="btn btn-secondary" data-cta="text" data-location="contact">
              Text Photos
            </a>
          </div>
        </div>

        <div style="max-width: 800px; margin: 0 auto; width: 100%;">
          <div id="estimate-form-container-es-contact"></div>
        </div>
        
      </div>
    </section>
  </main>
  
  <Footer lang={lang} />
</BaseLayout>

<script>
  import React from 'react';
  import { createRoot } from 'react-dom/client';
  import EstimateForm from '../../components/EstimateForm';

  const container = document.getElementById('estimate-form-container-es-contact');
  if (container) {
    const root = createRoot(container);
    root.render(React.createElement(EstimateForm, { lang: 'en' }));
  }
</script>

<style>
  @media (min-width: 768px) {
    .container {
      grid-template-columns: 1fr 2fr !important;
    }
    .contact-info {
      text-align: left !important;
      align-items: flex-start;
    }
    .contact-info div {
      justify-content: flex-start !important;
    }
  }
</style>
